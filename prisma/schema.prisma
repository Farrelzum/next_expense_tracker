generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Expense {
  id        String   @id @default(cuid())
  title     String
  amount    Int      // Przechowujemy wartość w groszach (np. 1550 = 15.50 PLN) aby uniknąć błędów zaokrągleń wynikających z Float
  category  String
  date      DateTime
  createdAt DateTime @default(now())
}